{
  "info": {
    "_postman_id": "c1f72c3c-41ef-4cc5-ad70-e22b1c24bb43",
    "name": "Healthy Lab — Mobile App API Collection (Flutter Ready v1.0)",
    "description": "مجموعة بوست مان المتكاملة لاختبار كافة واجهات تطبيق المريض (Flutter Mobile App API) مع سكربتات فحص أوتوماتيكية (Automated Tests) وحفظ التوكن تلقائياً.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8001/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication & Onboarding (المصادقة والتسجيل)",
      "item": [
        {
          "name": "Send OTP (إرسال رمز التحقق)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"07700000000\",\n  \"agreed_to_terms\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/mobile/auth/send-otp",
              "host": ["{{base_url}}"],
              "path": ["mobile", "auth", "send-otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "pm.test('Response status is true', function () { pm.expect(jsonData.status).to.eql(true); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify OTP & Get Token (التحقق وحفظ التوكن أوتوماتيكياً)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"07700000000\",\n  \"otp_code\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/mobile/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["mobile", "auth", "verify-otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "pm.test('Token received', function () { pm.expect(jsonData.token).to.be.a('string'); });",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Complete Profile (إكمال الملف الشخصي)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
